@page
@model SocialStrats.Pages.PrivacyModel
@{
ViewData["Title"] = "Privacy Policy";
}

@section Styles {
<style>
    :root {
        --primary:#0066FF;
        --accent:#FF6B00;
        --success:#00D084;
        --text:#0F172A;
        --muted:#64748B;
        --border:rgba(0,0,0,0.08);
        --shadow:rgba(15,23,42,0.10);
        --card:#ffffff;
        --bg:#f6f8ff;
    }

    body, p, div, span, h1, h2, h3, h4, h5, h6, label { cursor: default !important; }
    a, button { cursor: pointer !important; }

    .privacy-hero {
        background: radial-gradient(1200px 500px at 10% 10%, rgba(0,102,255,0.20), transparent 60%),
        radial-gradient(900px 400px at 90% 20%, rgba(255,107,0,0.18), transparent 60%),
        linear-gradient(135deg, #ffffff, #f8fbff);
        border: 1px solid var(--border);
        border-radius: 26px;
        box-shadow: 0 10px 32px var(--shadow);
        padding: 48px 32px;
        margin-bottom: 32px;
        text-align: center;
    }

    .privacy-hero h1 {
        font-weight: 950;
        letter-spacing: -0.8px;
        color: var(--text);
        font-size: clamp(32px, 4vw, 48px);
        margin-bottom: 16px;
    }

    .privacy-hero p {
        color: var(--muted);
        font-weight: 650;
        font-size: 16px;
        max-width: 65ch;
        margin: 0 auto;
    }

    .privacy-nav {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 26px;
        padding: 24px;
        margin-bottom: 32px;
        box-shadow: 0 10px 32px var(--shadow);
        position: sticky;
        top: 20px;
        z-index: 100;
    }

    .privacy-nav h3 {
        font-size: 14px;
        font-weight: 950;
        color: var(--text);
        margin-bottom: 16px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .nav-link-item {
        padding: 10px 14px;
        border-radius: 12px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        text-decoration: none;
        transition: all .15s ease;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .nav-link-item:hover {
        background: rgba(0,102,255,0.06);
        border-color: rgba(0,102,255,0.20);
        color: var(--primary);
    }

    .nav-link-item.active {
        background: rgba(0,102,255,0.10);
        border-color: rgba(0,102,255,0.30);
        color: var(--primary);
        font-weight: 900;
    }

    .privacy-section {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 26px;
        padding: 32px;
        margin-bottom: 24px;
        box-shadow: 0 10px 32px var(--shadow);
        scroll-margin-top: 100px;
    }

    .privacy-section h2 {
        font-size: 24px;
        font-weight: 950;
        color: var(--text);
        margin-bottom: 20px;
        letter-spacing: -0.4px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .privacy-section h3 {
        font-size: 18px;
        font-weight: 900;
        color: var(--text);
        margin: 24px 0 12px 0;
    }

    .privacy-section p {
        color: var(--muted);
        font-weight: 650;
        font-size: 15px;
        line-height: 1.7;
        margin-bottom: 16px;
    }

    .privacy-section ul {
        color: var(--muted);
        font-weight: 650;
        font-size: 15px;
        line-height: 1.7;
        margin-bottom: 16px;
        padding-left: 24px;
    }

    .privacy-section li {
        margin-bottom: 8px;
    }

    .privacy-section strong {
        color: var(--text);
        font-weight: 900;
    }

    .highlight-box {
        background: linear-gradient(135deg, rgba(0,102,255,0.06), rgba(255,107,0,0.04));
        border: 1px solid rgba(0,102,255,0.20);
        border-radius: 18px;
        padding: 20px;
        margin: 20px 0;
    }

    .highlight-box p {
        margin: 0;
        color: var(--text);
        font-weight: 750;
    }

    .icon-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(0,102,255,0.10), rgba(255,107,0,0.08));
        font-size: 18px;
    }

    .contact-card {
        background: linear-gradient(135deg, #f8fbff, #fff);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 24px;
        margin-top: 32px;
    }

    .contact-card h3 {
        font-size: 18px;
        font-weight: 950;
        color: var(--text);
        margin-bottom: 12px;
    }

    .contact-card p {
        color: var(--muted);
        font-weight: 650;
        margin: 0;
    }

    .contact-card a {
        color: var(--primary);
        font-weight: 850;
        text-decoration: none;
    }

    .contact-card a:hover {
        text-decoration: underline;
    }

    .last-updated {
        text-align: center;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        padding: 20px;
        margin-top: 32px;
    }

    @@media (max-width: 991px) {
    .privacy-nav {
        position: relative;
        top: 0;
    }

    .privacy-hero {
        padding: 32px 24px;
    }

    .privacy-section {
        padding: 24px 20px;
    }
    }
</style>
}

<div class="privacy-hero">
    <h1>🔒 Privacy Policy</h1>
    <p>
        Your privacy matters. SocialStrats is designed with transparency in mind — we explain exactly what data we collect,
        how we use it, and your rights. This policy covers our flight deals radar service.
    </p>
</div>

<div class="row g-4">
    <!-- Navigation Sidebar -->
    <div class="col-12 col-lg-3">
        <div class="privacy-nav">
            <h3>📑 Quick Navigation</h3>
            <div class="nav-links">
                <a href="#overview" class="nav-link-item">🎯 Overview</a>
                <a href="#data-collection" class="nav-link-item">📊 Data Collection</a>
                <a href="#data-usage" class="nav-link-item">⚙️ How We Use Data</a>
                <a href="#third-party" class="nav-link-item">🔗 Third-Party Services</a>
                <a href="#cookies" class="nav-link-item">🍪 Cookies & Storage</a>
                <a href="#security" class="nav-link-item">🛡️ Security</a>
                <a href="#your-rights" class="nav-link-item">✅ Your Rights</a>
                <a href="#changes" class="nav-link-item">📝 Policy Updates</a>
                <a href="#contact" class="nav-link-item">💬 Contact Us</a>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="col-12 col-lg-9">
        <!-- Overview -->
        <section id="overview" class="privacy-section">
            <h2><span class="icon-badge">🎯</span> Overview</h2>
            <p>
                SocialStrats is a flight deals aggregation and strategy platform that helps users find affordable flights across Europe.
                We prioritize your privacy and are committed to being transparent about our data practices.
            </p>
            <div class="highlight-box">
                <p>
                    <strong>Key principle:</strong> We collect only what's necessary to provide our service and never sell your personal data to third parties.
                </p>
            </div>
        </section>

        <!-- Data Collection -->
        <section id="data-collection" class="privacy-section">
            <h2><span class="icon-badge">📊</span> What Data We Collect</h2>

            <h3>Information You Provide</h3>
            <ul>
                <li><strong>Search Parameters:</strong> Origin airports, travel dates, budget preferences, and filter settings you enter</li>
                <li><strong>User Preferences:</strong> Currency selection, saved filters, and UI customization settings stored locally</li>
            </ul>

            <h3>Automatically Collected Information</h3>
            <ul>
                <li><strong>Technical Data:</strong> Browser type, device information, IP address, and operating system</li>
                <li><strong>Usage Analytics:</strong> Pages viewed, features used, search patterns, and interaction data</li>
                <li><strong>Performance Metrics:</strong> Page load times, API response times, and error logs</li>
            </ul>

            <h3>Flight Data</h3>
            <p>
                We fetch real-time flight pricing and route information from airline APIs (primarily Ryanair).
                This data is displayed to you but not permanently stored on our servers beyond temporary caching for performance.
            </p>
        </section>

        <!-- Data Usage -->
        <section id="data-usage" class="privacy-section">
            <h2><span class="icon-badge">⚙️</span> How We Use Your Data</h2>
            <p>We use the collected information for the following purposes:</p>
            <ul>
                <li><strong>Service Delivery:</strong> Process your searches, display flight deals, and provide route analytics</li>
                <li><strong>Personalization:</strong> Remember your preferences and settings for a better user experience</li>
                <li><strong>Performance Optimization:</strong> Improve app speed, fix bugs, and enhance features</li>
                <li><strong>Analytics:</strong> Understand usage patterns to prioritize new features and improvements</li>
                <li><strong>Security:</strong> Detect and prevent fraud, abuse, and security incidents</li>
                <li><strong>Legal Compliance:</strong> Meet regulatory requirements and respond to legal requests</li>
            </ul>
        </section>

        <!-- Third Party -->
        <section id="third-party" class="privacy-section">
            <h2><span class="icon-badge">🔗</span> Third-Party Services</h2>

            <h3>Flight Data Providers</h3>
            <p>
                We integrate with <strong>Ryanair's API</strong> to fetch live flight prices and availability.
                When you perform a search, your query parameters are sent to their servers.
                Refer to <a href="https://www.ryanair.com/privacy" target="_blank">Ryanair's Privacy Policy</a> for details on their data handling.
            </p>

            <h3>Mapping Services</h3>
            <p>
                We use <strong>OpenStreetMap</strong> via Leaflet.js for interactive maps.
                Map tiles are loaded from OSM servers, which may log your IP address.
                See <a href="https://wiki.osmfoundation.org/wiki/Privacy_Policy" target="_blank">OpenStreetMap's Privacy Policy</a>.
            </p>

            <h3>Analytics (If Applicable)</h3>
            <p>
                If we implement analytics tools like Google Analytics or similar services in the future,
                we will update this policy and provide opt-out mechanisms.
            </p>
        </section>

        <!-- Cookies -->
        <section id="cookies" class="privacy-section">
            <h2><span class="icon-badge">🍪</span> Cookies & Local Storage</h2>
            <p>
                SocialStrats uses <strong>browser local storage</strong> (not traditional cookies) to remember your preferences:
            </p>
            <ul>
                <li>Search inputs (origin, currency, date, budget)</li>
                <li>Filter settings (distance, hot threshold, sorting preferences)</li>
                <li>UI state (map size, follow mode, auto-zoom)</li>
            </ul>
            <div class="highlight-box">
                <p>
                    <strong>Note:</strong> This data is stored locally in your browser and is not transmitted to our servers.
                    You can clear it anytime using your browser's developer tools or by clicking the "Reset" button in the app.
                </p>
            </div>
        </section>

        <!-- Security -->
        <section id="security" class="privacy-section">
            <h2><span class="icon-badge">🛡️</span> Data Security</h2>
            <p>
                We implement industry-standard security measures to protect your data:
            </p>
            <ul>
                <li><strong>HTTPS Encryption:</strong> All data transmitted between your browser and our servers is encrypted</li>
                <li><strong>Secure APIs:</strong> We use authenticated endpoints and rate limiting to prevent abuse</li>
                <li><strong>Minimal Data Retention:</strong> We don't store personal search histories on our servers</li>
                <li><strong>Regular Updates:</strong> We keep our dependencies and infrastructure up to date with security patches</li>
            </ul>
            <p>
                However, no method of transmission over the internet is 100% secure.
                While we strive to protect your data, we cannot guarantee absolute security.
            </p>
        </section>

        <!-- Your Rights -->
        <section id="your-rights" class="privacy-section">
            <h2><span class="icon-badge">✅</span> Your Privacy Rights</h2>
            <p>
                Depending on your location, you may have the following rights under GDPR, CCPA, or similar regulations:
            </p>
            <ul>
                <li><strong>Access:</strong> Request a copy of the data we hold about you</li>
                <li><strong>Correction:</strong> Update or correct inaccurate information</li>
                <li><strong>Deletion:</strong> Request deletion of your data (right to be forgotten)</li>
                <li><strong>Portability:</strong> Receive your data in a machine-readable format</li>
                <li><strong>Opt-Out:</strong> Refuse certain data processing activities</li>
                <li><strong>Withdraw Consent:</strong> Revoke previously given consent at any time</li>
            </ul>
            <p>
                To exercise these rights, please contact us using the information in the "Contact Us" section below.
            </p>
        </section>

        <!-- Changes -->
        <section id="changes" class="privacy-section">
            <h2><span class="icon-badge">📝</span> Changes to This Policy</h2>
            <p>
                We may update this Privacy Policy from time to time to reflect changes in our practices,
                legal requirements, or service features. When we make significant changes:
            </p>
            <ul>
                <li>We'll update the "Last Updated" date at the bottom of this page</li>
                <li>We'll notify users via a prominent notice in the app</li>
                <li>For material changes, we may send email notifications (if we have your email)</li>
            </ul>
            <p>
                We encourage you to review this policy periodically to stay informed about how we protect your privacy.
            </p>
        </section>

        <!-- Contact -->
        <section id="contact" class="privacy-section">
            <h2><span class="icon-badge">💬</span> Contact Us</h2>
            <p>
                If you have questions, concerns, or requests regarding this Privacy Policy or our data practices,
                please reach out to us:
            </p>
            <div class="contact-card">
                <h3>Get in Touch</h3>
                <p><strong>Email:</strong> <a href="mailto:privacy@socialstrats.com">privacy@socialstrats.com</a></p>
                <p><strong>Response Time:</strong> We aim to respond within 48 hours</p>
                <p style="margin-top: 16px;">
                    For data subject access requests or GDPR-related inquiries,
                    please include "Privacy Request" in your email subject line.
                </p>
            </div>
        </section>

        <div class="last-updated">
            <strong>Last Updated:</strong> December 29, 2025
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Smooth scroll to sections with offset for sticky nav
    document.querySelectorAll('.nav-link-item').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href').substring(1);
            const targetSection = document.getElementById(targetId);

            if (targetSection) {
                const offset = 120;
                const targetPosition = targetSection.offsetTop - offset;
                window.scrollTo({
                    top: targetPosition,
                    behavior: 'smooth'
                });

                // Update active state
                document.querySelectorAll('.nav-link-item').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            }
        });
    });

    // Update active nav item on scroll
    window.addEventListener('scroll', () => {
        const sections = document.querySelectorAll('.privacy-section');
        const navLinks = document.querySelectorAll('.nav-link-item');

        let currentSection = '';
        sections.forEach(section => {
            const sectionTop = section.offsetTop - 150;
            if (window.scrollY >= sectionTop) {
                currentSection = section.getAttribute('id');
            }
        });

        navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${currentSection}`) {
                link.classList.add('active');
            }
        });
    });
</script>
}