<script>
    // Navbar scroll effect
    window.addEventListener('scroll', function() {
        const navbar = document.getElementById('mainNav');
        const scrollProgress = document.getElementById('scrollProgress');

        if (window.scrollY > 50) {
            navbar.classList.add('scrolled');
        } else {
            navbar.classList.remove('scrolled');
        }

        // Update scroll progress
        const windowHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (window.scrollY / windowHeight) * 100;
        scrollProgress.style.width = scrolled + '%';
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });

    // Language dropdown open/close
    (function () {
        const btn = document.querySelector('[data-lang-btn]');
        const menu = document.querySelector('[data-lang-menu]');
        if (!btn || !menu) return;

        function close() {
            menu.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
        }
        function toggle() {
            const isOpen = !menu.hidden;
            menu.hidden = isOpen;
            btn.setAttribute('aria-expanded', String(!isOpen));
        }

        btn.addEventListener('click', (e) => { e.preventDefault(); toggle(); });

        document.addEventListener('click', (e) => {
            if (!menu.hidden && !e.target.closest('.ss-lang')) close();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') close();
        });
    })();


    // Close mobile nav after clicking any section link or CTA
        document.addEventListener('click', function (e) {
        const a = e.target.closest('a.js-navlink');
        if (!a) return;

        const nav = document.getElementById('ssNav2');
        if (!nav) return;

        if (nav.classList.contains('show')) {
        const bs = bootstrap.Collapse.getOrCreateInstance(nav);
        bs.hide();
            // Close the menu when clicking a language link (so it doesn't stay open during navigation)
            menu.addEventListener('click', (e) => {
                const link = e.target.closest('a.ss-lang-item');
                if (link) close();
            });

        }
    });
        

</script>
