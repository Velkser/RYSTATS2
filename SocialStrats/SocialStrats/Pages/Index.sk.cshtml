@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1"></script>

    <script>
        function setScanLoading(isLoading) {
            const btns = Array.from(document.querySelectorAll("[data-scan-btn]"));

            for (const b of btns) {
                b.classList.toggle("is-loading", !!isLoading);
                b.disabled = !!isLoading;
                b.setAttribute("aria-busy", isLoading ? "true" : "false");

                const label = b.querySelector(".cta-label");
                if (label) {
                    if (!b.dataset.labelDefault) b.dataset.labelDefault = label.textContent || "";
                    label.textContent = isLoading ? "Scanning…" : (b.dataset.labelDefault || "Run live deal scan");
                }
            }
}

        function renderDealsLoading() {
            const el = document.getElementById("dealsList");
            if (!el) return;

            el.innerHTML = `
        <div class="deals-skeleton" aria-label="Loading deals">
            <div class="sk"></div>
            <div class="sk"></div>
            <div class="sk"></div>
            <div class="sk"></div>
        </div>
    `;
        }

        const AGENT_ENDPOINT = "/api/agent/chat";
        let agentState = { thread: [], pending: false };

        function getAgentPanel() {
            return document.getElementById("agentPanel");
        }

        function getAgentInputValue(id) {
            const el = document.getElementById(id);
            const value = (el?.value || "").toString().trim();
            return value || null;
        }

        function getAgentIntValue(id) {
            const value = getAgentInputValue(id);
            if (value == null) return null;
            const parsed = parseInt(value, 10);
            return Number.isFinite(parsed) ? parsed : null;
        }

        function getAgentMaxDistance() {
            const plannerDistance = getAgentIntValue("agentMaxDistance");
            if (plannerDistance != null) return plannerDistance;

            const filterDistance = getAgentIntValue("maxDist");
            return (filterDistance != null && filterDistance < 4000) ? filterDistance : null;
        }

        function buildInitialAgentThread() {
            const panel = getAgentPanel();
            const intro = panel?.dataset.agentInitial || "Napíš mi kam chceš ísť, aký máš rozpočet a ako ďaleko chceš letieť.";
            const sampleUser = panel?.dataset.agentSampleUser || "";
            const sampleReply = panel?.dataset.agentSampleReply || "";
            const thread = [{
                role: "assistant",
                content: intro
            }];
            if (sampleUser && sampleReply) {
                thread.push(
                    { role: "user", content: sampleUser },
                    { role: "assistant", content: sampleReply }
                );
            }
            return thread;
        }

        function setAgentMeta(text) {
            const meta = document.getElementById("agentMeta");
            if (!meta) return;
            meta.textContent = text || meta.dataset.defaultText || "";
        }

        function setAgentPending(isPending) {
            agentState.pending = !!isPending;

            const button = document.getElementById("agentSendBtn");
            const label = button?.querySelector(".ss-agent-send-label");
            if (button) button.disabled = !!isPending;
            if (label) {
                label.textContent = isPending
                    ? (button.dataset.labelBusy || "Premýšľam...")
                    : (button.dataset.labelDefault || "Opýtať sa agenta");
            }

            const composer = document.getElementById("agentComposer");
            if (composer) composer.disabled = !!isPending;
        }

        function collectAgentTravelContext() {
            const maxBudget = getAgentIntValue("maxBudget");
            const maxDeals = getAgentIntValue("maxDeals");
            const minDistance = getAgentIntValue("minDist");

            return {
                origin: normalizeOriginInput() || null,
                month: getAgentInputValue("month"),
                currency: getAgentInputValue("currency"),
                maxBudget: maxBudget,
                maxDeals: maxDeals,
                destinationIdea: getAgentInputValue("agentDestinationIdea"),
                destinationSearch: getAgentInputValue("destSearch"),
                maxDistanceKm: getAgentMaxDistance(),
                minDistanceKm: (minDistance != null && minDistance > 0) ? minDistance : null,
                preferWeekend: !!document.getElementById("preferWeekend")?.checked,
                onlyHotDeals: !!document.getElementById("onlyHot")?.checked,
                notes: getAgentInputValue("agentTripNotes")
            };
        }

        function applyAgentTravelContext(context) {
            if (!context) return;

            if (context.origin && /^[a-z]{3}$/i.test(context.origin) && document.getElementById("origin")) {
                document.getElementById("origin").value = context.origin.toUpperCase();
            }
            if (context.month && document.getElementById("month")) {
                document.getElementById("month").value = context.month;
            }
            if (context.currency && document.getElementById("currency")) {
                document.getElementById("currency").value = context.currency;
            }
            if (Number.isFinite(Number(context.maxBudget)) && document.getElementById("maxBudget")) {
                document.getElementById("maxBudget").value = `${context.maxBudget}`;
            }
            if (Number.isFinite(Number(context.maxDeals)) && document.getElementById("maxDeals")) {
                document.getElementById("maxDeals").value = `${context.maxDeals}`;
            }
            if (typeof context.destinationIdea === "string" && document.getElementById("agentDestinationIdea")) {
                document.getElementById("agentDestinationIdea").value = context.destinationIdea;
            }
            if (typeof context.destinationSearch === "string" && document.getElementById("destSearch")) {
                document.getElementById("destSearch").value = context.destinationSearch;
            }
            if (Number.isFinite(Number(context.maxDistanceKm)) && document.getElementById("agentMaxDistance")) {
                document.getElementById("agentMaxDistance").value = `${context.maxDistanceKm}`;
            }
            if (typeof context.notes === "string" && document.getElementById("agentTripNotes")) {
                document.getElementById("agentTripNotes").value = context.notes;
            }
            if (typeof context.preferWeekend === "boolean" && document.getElementById("preferWeekend")) {
                document.getElementById("preferWeekend").checked = context.preferWeekend;
            }
            if (typeof context.onlyHotDeals === "boolean" && document.getElementById("onlyHot")) {
                document.getElementById("onlyHot").checked = context.onlyHotDeals;
            }
        }

        function renderAgentContextSummary(context = collectAgentTravelContext()) {
            const summary = document.getElementById("agentSummary");
            if (!summary) return;

            const items = [];
            if (context.origin) items.push(`Odlet: ${context.origin}`);
            if (context.month) items.push(`Mesiac: ${context.month}`);
            if (context.maxBudget != null && Number.isFinite(Number(context.maxBudget)) && context.currency) {
                items.push(`Rozpočet: ${currencySymbol(context.currency)}${Number(context.maxBudget).toFixed(0)}`);
            }

            const destinationIdea = context.destinationIdea || context.destinationSearch;
            if (destinationIdea) items.push(`Vibe: ${destinationIdea}`);
            if (context.maxDistanceKm != null && Number.isFinite(Number(context.maxDistanceKm)) && Number(context.maxDistanceKm) > 0) {
                items.push(`Limit: ${Number(context.maxDistanceKm).toFixed(0)} km`);
            }
            if (context.preferWeekend) items.push("Víkend");
            if (context.onlyHotDeals) items.push("Hot deals");

            summary.innerHTML = items.length
                ? items.map(item => `<span class="ss-agent-summary-pill">${escapeHtml(item)}</span>`).join("")
                : `<span class="ss-agent-summary-empty">Napíš destináciu alebo vibe, budget a limit vzdialenosti. Aktuálne nastavenia skenu sa pripoja automaticky.</span>`;
        }

        function renderAgentSuggestedReplies(replies) {
            const container = document.getElementById("agentQuickReplies");
            if (!container || !Array.isArray(replies) || replies.length === 0) return;

            container.innerHTML = replies.slice(0, 4).map(reply => `
                <button class="ss-agent-chip" type="button" data-agent-prompt="${escapeHtml(reply)}">${escapeHtml(reply)}</button>
            `).join("");
        }

        function renderAgentThread() {
            const thread = document.getElementById("agentThread");
            const panel = getAgentPanel();
            if (!thread) return;

            const html = agentState.thread.map(message => {
                const role = message.role === "user" ? "user" : "assistant";
                const roleLabel = role === "user" ? "Ty" : "Agent";
                return `
                    <article class="ss-agent-msg ${role}">
                        <div class="ss-agent-msg-role">${escapeHtml(roleLabel)}</div>
                        <div class="ss-agent-msg-body">${escapeHtml(message.content || "")}</div>
                    </article>
                `;
            }).join("");

            const typing = agentState.pending ? `
                <article class="ss-agent-msg assistant is-typing">
                    <div class="ss-agent-msg-role">Agent</div>
                    <div class="ss-agent-msg-body">
                        <span>${escapeHtml(panel?.dataset.agentThinking || "Premýšľam nad tvojím tripom...")}</span>
                        <span class="ss-agent-dots" aria-hidden="true"><span></span><span></span><span></span></span>
                    </div>
                </article>
            ` : "";

            thread.innerHTML = html + typing;
            thread.scrollTop = thread.scrollHeight;
        }

        async function sendAgentMessage(forcedText) {
            if (agentState.pending) return;

            const input = document.getElementById("agentComposer");
            const text = (forcedText ?? input?.value ?? "").trim();
            if (!text) return;

            agentState.thread.push({ role: "user", content: text });
            if (input) input.value = "";
            renderAgentThread();
            setAgentPending(true);

            try {
                const response = await fetch(AGENT_ENDPOINT, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        messages: agentState.thread,
                        travelContext: collectAgentTravelContext()
                    })
                });

                if (!response.ok) {
                    throw new Error(await response.text());
                }

                const payload = await response.json();
                applyAgentTravelContext(payload.travelContext);

                if (payload.assistantMessage?.content) {
                    agentState.thread.push(payload.assistantMessage);
                }

                setAgentMeta(payload.travelBrief || "");
                renderAgentContextSummary(payload.travelContext);
                renderAgentSuggestedReplies(payload.suggestedReplies);
                persistUiToStorage?.();
            } catch (error) {
                const panel = getAgentPanel();
                agentState.thread.push({
                    role: "assistant",
                    content: panel?.dataset.agentError || "UI pre agenta je pripravené, ale reálny AI worker ešte nie je napojený."
                });
                showToast(panel?.dataset.agentErrorToast || "Endpoint pre AI handoff zatiaľ nie je hotový.", "warning");
            } finally {
                setAgentPending(false);
                renderAgentThread();
            }
        }

        function bindAgentContextInputs() {
            const ids = ["origin", "month", "currency", "maxBudget", "maxDeals", "destSearch", "minDist", "maxDist", "onlyHot", "preferWeekend", "agentDestinationIdea", "agentMaxDistance", "agentTripNotes"];

            for (const id of ids) {
                const el = document.getElementById(id);
                if (!el || el.dataset.agentBound === "true") continue;

                el.dataset.agentBound = "true";
                const evt = (el.type === "checkbox" || el.tagName === "SELECT") ? "change" : "input";
                el.addEventListener(evt, () => renderAgentContextSummary());
            }
        }

        function bindAgentUi() {
            const panel = getAgentPanel();
            if (!panel) return;

            agentState.thread = buildInitialAgentThread();
            agentState.pending = false;

            const form = document.getElementById("agentForm");
            if (form && form.dataset.bound !== "true") {
                form.dataset.bound = "true";
                form.addEventListener("submit", async (event) => {
                    event.preventDefault();
                    await sendAgentMessage();
                });
            }

            const replies = document.getElementById("agentQuickReplies");
            if (replies && replies.dataset.bound !== "true") {
                replies.dataset.bound = "true";
                replies.addEventListener("click", async (event) => {
                    const button = event.target.closest("[data-agent-prompt]");
                    if (!button || agentState.pending) return;

                    const prompt = (button.dataset.agentPrompt || button.textContent || "").trim();
                    if (!prompt) return;

                    const input = document.getElementById("agentComposer");
                    if (input) input.value = prompt;
                    await sendAgentMessage(prompt);
                });
            }

            bindAgentContextInputs();
            setAgentMeta(panel.dataset.agentMetaDefault || "");
            renderAgentThread();
            renderAgentContextSummary();
            setAgentPending(false);
        }

        // =========================
        // Airport picker (Origin + Destination)
        // =========================
        let airportPickerCache = null;
        let airportPickerTargetId = "origin";

        function openDestinationPicker() {
            openAirportPicker("destSearch", { title: "Choose destination airport" });
        }

        function getPickerCurrentIata() {
            const el = document.getElementById(airportPickerTargetId);
            const raw = (el?.value || "").toString().trim().toUpperCase();

            // If user typed "Barcelona / BCN / Spain", try to extract a standalone IATA code
            const m = raw.match(/\b[A-Z]{3}\b/);
            if (m) return m[0];

            // Or if they typed exactly 3 letters
            if (raw.length === 3 && /^[A-Z]{3}$/.test(raw)) return raw;

            return "";
        }

        function setPickerValue(iata) {
            if (airportPickerTargetId === "origin") {
                setOrigin(iata);
                return;
            }

            const el = document.getElementById(airportPickerTargetId);
            if (el) el.value = iata;

            // Immediately apply so it feels “real”
            applyClientFilters(true);
            renderAgentContextSummary();
        }

        function openAirportPicker(targetId = "origin", opts = {}) {
            airportPickerTargetId = targetId || "origin";

            const modal = document.getElementById("airportModal");
            if (!modal) return;

            const titleEl = document.getElementById("airportModalTitle");
            if (titleEl) {
                titleEl.textContent = opts.title || (
                    airportPickerTargetId === "origin"
                        ? "Choose origin airport"
                        : "Choose destination airport"
                );
            }

            // If airports not loaded yet, load then reopen
            if (!airportsIndex || Object.keys(airportsIndex).length === 0) {
                loadAirportsList()
                    .then(() => openAirportPicker(airportPickerTargetId, opts))
                    .catch(() => showToast("Airports list not loaded yet. Try again.", "warning"));
                return;
            }

            // Build a sorted cache once
            if (!airportPickerCache) {
                airportPickerCache = Object.entries(airportsIndex)
                    .map(([iata, info]) => ({
                        iata,
                        name: (info?.name || iata).toString(),
                        country: (info?.country || "").toString()
                    }))
                    .sort((a, b) => (a.name || "").localeCompare(b.name || ""));
            }

            modal.classList.add("open");
            modal.setAttribute("aria-hidden", "false");

            // Prevent background scroll while modal open
            document.body.style.overflow = "hidden";

            const q = document.getElementById("airportModalSearch");
            if (q) q.value = "";

            renderAirportPickerList("");

            // Focus search
            setTimeout(() => q && q.focus(), 40);
        }

        function closeAirportPicker(_fromBackdrop) {
            const modal = document.getElementById("airportModal");
            if (!modal) return;

            modal.classList.remove("open");
            modal.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
        }

        function renderAirportPickerList(query) {
            const listEl = document.getElementById("airportModalList");
            const countEl = document.getElementById("airportModalCount");
            if (!listEl) return;

            const q = (query || "").trim().toLowerCase();
            const current = getPickerCurrentIata();

            // Filter + cap to keep DOM fast
            const items = (airportPickerCache || [])
                .filter(a => {
                    if (!q) return true;
                    return (
                        a.iata.toLowerCase().includes(q) ||
                        a.name.toLowerCase().includes(q) ||
                        (a.country || "").toLowerCase().includes(q)
                    );
                })
                .slice(0, 300);

            listEl.innerHTML = "";

            for (const a of items) {
                const row = document.createElement("div");
                row.className = "airport-item" + (a.iata === current ? " active" : "");
                row.innerHTML = `
            <div>
                <div class="airport-name">${escapeHtml(a.name)}</div>
                <div class="airport-meta">${escapeHtml(a.country || "")}</div>
            </div>
            <div class="airport-code">${escapeHtml(a.iata)}</div>
        `;

                row.addEventListener("click", () => {
                    setPickerValue(a.iata);
                    persistUiToStorage?.(); // safe if present
                    closeAirportPicker();
                });

                listEl.appendChild(row);
            }

            if (countEl) {
                if (!airportPickerCache) countEl.textContent = "—";
                else if (q) countEl.textContent = `${items.length} matches`;
                else countEl.textContent = `${airportPickerCache.length} airports`;
            }
}

        function bindAirportPicker() {
            const search = document.getElementById("airportModalSearch");
            if (search) {
                search.addEventListener("input", (e) => renderAirportPickerList(e.target.value));
            }

            // Esc closes when open
            document.addEventListener("keydown", (e) => {
                const modal = document.getElementById("airportModal");
                if (!modal || !modal.classList.contains("open")) return;
                if (e.key === "Escape") closeAirportPicker();
            });
        }



        let heroHistogramChart = null;
        let heroScatterChart = null;

        function renderHeroAnalytics(deals, currency) {
            try {
                if (!Array.isArray(deals) || deals.length < 3) return;

                const histCanvas = document.getElementById("heroPriceHistogram");
                const scatterCanvas = document.getElementById("heroValueScatter");
                if (!histCanvas || !scatterCanvas) return;

                const num = v => {
                    if (typeof v === "number") return v;
                    if (typeof v === "string") {
                        const n = parseFloat(v.replace(",", "."));
                        return Number.isFinite(n) ? n : NaN;
                    }
                    return NaN;
                };

                // =========================
                // Histogram (prices)
                // =========================
                const prices = deals.map(d => num(d.price)).filter(Number.isFinite);
                if (prices.length < 3) return;

                const bins = 10;
                const min = Math.min(...prices);
                const max = Math.max(...prices);
                const range = Math.max(0.01, max - min);
                const step = range / bins;

                const hist = new Array(bins).fill(0);
                const binRanges = new Array(bins).fill(null).map((_, i) => ({
                    min: min + i * step,
                    max: min + (i + 1) * step
                }));

                prices.forEach(p => {
                    const idx = Math.min(bins - 1, Math.floor((p - min) / step));
                    hist[idx]++;
                });

                const histLabels = hist.map((_, i) => {
                    const a = min + i * step;
                    const b = min + (i + 1) * step;
                    return `${Math.round(a)}–${Math.round(b)}`;
                });

                if (heroHistogramChart) heroHistogramChart.destroy();
                heroHistogramChart = new Chart(histCanvas, {
                    type: "bar",
                    data: {
                        labels: histLabels,
                        datasets: [{
                            data: hist,
                            borderRadius: 6,
                            backgroundColor: "rgba(0,102,255,0.45)"
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        onClick: (evt, elements) => {
                            if (!elements || !elements.length) return;

                            const binIndex = elements[0].index;
                            const r = binRanges[binIndex];
                            if (!r) return;

                            // select ALL deals in bin (using same 'deals' array indices)
                            const indices = [];
                            for (let i = 0; i < deals.length; i++) {
                                const p = num(deals[i].price);
                                if (!Number.isFinite(p)) continue;
                                const inBin = (binIndex === bins - 1)
                                    ? (p >= r.min && p <= r.max)
                                    : (p >= r.min && p < r.max);

                                if (inBin) indices.push(i);
                            }

                            selectDealsFromCharts(indices);
                        },
                        scales: {
                            x: { ticks: { autoSkip: true, maxRotation: 0 } },
                            y: { ticks: { precision: 0 } }
                        }
                    }
                });

                // =========================
                // Scatter (€ / km vs distance)
                // =========================
                const scatterData = deals
                    .map((d, idx) => ({
                        x: num(d.distanceKm),
                        y: num(d.pricePerKm),
                        _dealIndex: idx
                    }))
                    .filter(p =>
                        Number.isFinite(p.x) &&
                        Number.isFinite(p.y) &&
                        p.x > 0 &&
                        p.y > 0
                    );

                if (heroScatterChart) heroScatterChart.destroy();
                heroScatterChart = new Chart(scatterCanvas, {
                    type: "scatter",
                    data: {
                        datasets: [{
                            data: scatterData,
                            pointRadius: 4,
                            backgroundColor: "rgba(0,208,132,0.75)"
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        onClick: (evt, elements) => {
                            if (!elements || !elements.length) return;

                            const pt = heroScatterChart.data.datasets[0].data[elements[0].index];
                            if (!pt || typeof pt._dealIndex !== "number") return;

                            selectDealFromCharts(pt._dealIndex);
                        },
                        scales: {
                            x: { title: { display: true, text: "Distance (km)" } },
                            y: { title: { display: true, text: `€ / km (${currency})` } }
                        }
                    }
                });

            } catch (err) {
                console.error("Hero analytics failed:", err);
            }
}




