        /* =========================
   Inline rotating hero word – fixed alignment
   ========================= */

        .hero-inline {
            display: inline-flex;
            align-items: center;
            gap: 0.35ch;
        }

        .hero-rotator {
            position: relative;
            display: inline-block;
