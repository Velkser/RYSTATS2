        function toggleMapFullscreen(forceOn) {
            const on = (typeof forceOn === "boolean") ? forceOn : !uiState.mapFullscreen;
            uiState.mapFullscreen = on;

            document.body.classList.toggle("map-fs", on);

            const bar = document.getElementById("mapFsBar");
            if (bar) {
                bar.style.display = on ? "flex" : "none";
                bar.setAttribute("aria-hidden", on ? "false" : "true");
            }

            // Optional native fullscreen (works in many browsers; iOS may ignore it)
            const mapEl = document.getElementById("map");
            if (on) {
                if (mapEl && mapEl.requestFullscreen) mapEl.requestFullscreen().catch(() => {});
            } else {
                if (document.fullscreenElement && document.exitFullscreen) document.exitFullscreen().catch(() => {});
            }

            // Leaflet needs a size recalculation after layout changes
            setTimeout(() => { if (map) map.invalidateSize(); }, 220);
        }

        // ESC closes fullscreen (desktop testing)
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && uiState.mapFullscreen) toggleMapFullscreen(false);
        });

        // If native fullscreen ends (user gesture), sync UI
        document.addEventListener("fullscreenchange", () => {
            if (!document.fullscreenElement && uiState.mapFullscreen) {
                uiState.mapFullscreen = false;
                document.body.classList.remove("map-fs");

                const bar = document.getElementById("mapFsBar");
                if (bar) { bar.style.display = "none"; bar.setAttribute("aria-hidden", "true"); }

                setTimeout(() => { if (map) map.invalidateSize(); }, 220);
            }
});


