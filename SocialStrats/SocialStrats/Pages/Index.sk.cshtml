        /* Feature tiles */
        .ss-hero-feature-row{
            margin-top: 14px;
            display:grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        /* =========================
   HERO ENTRY ANIMATION (instant on load)
   ========================= */

        .ss-hero {
            opacity: 0;
            transform: translateY(18px) scale(0.985);
            animation: heroEnter 0.65s cubic-bezier(.22,.9,.25,1) forwards;
        }

        @@keyframes heroEnter {
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
}

        /* Stagger children */
        .ss-hero-left > * {
            opacity: 0;
            transform: translateY(12px);
            animation: heroItemIn 0.55s ease-out forwards;
        }

        .ss-hero-left > *:nth-child(1) { animation-delay: .10s; }
        .ss-hero-left > *:nth-child(2) { animation-delay: .16s; }
        .ss-hero-left > *:nth-child(3) { animation-delay: .22s; }
        .ss-hero-left > *:nth-child(4) { animation-delay: .28s; }
        .ss-hero-left > *:nth-child(5) { animation-delay: .34s; }
        .ss-hero-left > *:nth-child(6) { animation-delay: .40s; }

        @@keyframes heroItemIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
}

        /* Right panel: subtle scale-in */
        .ss-hero-right {
            opacity: 0;
            transform: scale(0.96);
            animation: heroSideIn 0.6s ease-out forwards;
            animation-delay: .35s;
        }

        @@keyframes heroSideIn {
            to {
                opacity: 1;
                transform: scale(1);
            }
}

        /* Boost background glow only on entry */
        .ss-hero-bg {
            opacity: 0;
            animation:
                heroBgIn 0.8s ease-out forwards,
                ssHeroFloat 10s ease-in-out infinite;
        }

        @@keyframes heroBgIn {
            to { opacity: 1; }
}

        /* Reduced motion */
        @@media (prefers-reduced-motion: reduce) {
        .ss-hero,
        .ss-hero-left > *,
        .ss-hero-right,
        .ss-hero-bg {
            animation: none !important;
            opacity: 1 !important;
            transform: none !important;
        }
}




