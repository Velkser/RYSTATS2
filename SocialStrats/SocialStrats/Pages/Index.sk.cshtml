        // --- Airports list ---
        async function loadAirportsList() {
            const res = await fetch(`/api/ryanair/airports?lang=en`);
            if (!res.ok) throw new Error("airports failed");
            const data = await res.json();

            const datalist = document.getElementById("airportsList");
            datalist.innerHTML = "";
            airportsIndex = {};

            for (const a of data) {
                const iata = (a.iataCode || a.code || "").toString().toUpperCase().trim();
                if (!iata || iata.length !== 3) continue;

                const name = (a.name || a.seoName || iata).toString();
                const country = (a.countryName || a.country || "").toString();

                airportsIndex[iata] = { name, country };

                const opt = document.createElement("option");
                opt.value = `${iata} – ${name}${country ? " (" + country + ")" : ""}`;
                datalist.appendChild(opt);
            }
        }

        // --- Main Search ---
        // --- Main Search ---
        async function scanDeals() {
            const origin = normalizeOriginInput();
            const currency = document.getElementById('currency').value;
            const month = document.getElementById('month').value;
            const maxBudget = parseInt(document.getElementById('maxBudget').value || "100", 10);
            const maxDealsLimit = parseInt(document.getElementById('maxDeals').value || "40", 10);

            if (!origin || origin.length !== 3) {
                showToast("Enter a valid origin IATA code (e.g., BTS).", "warning");
                return;
            }
            if (!month) {
                showToast("Select a travel month.", "warning");
                return;
            }

            persistUiToStorage();
            clearMap();
            selectedDealKey = null;

            // Loading UI
            setScanLoading(true);
            renderDealsLoading();
            updateHeroKpis([], currency, true);
            renderHeroAnalytics([], currency);
            setHeroSessionStatus({
                lastScanText: document.getElementById("heroLastScan")?.textContent || "—",
                filtersActive: countActiveFilters(),
                modeText: "Fetching live fares…"
            });

            try {
                const url = `/api/ryanair/search?origin=${encodeURIComponent(origin)}&month=${encodeURIComponent(month)}&currency=${encodeURIComponent(currency)}&maxBudget=${maxBudget}&maxDeals=${maxDealsLimit}&lang=en`;
                const res = await fetch(url);
                if (!res.ok) throw new Error(await res.text());

                const payload = await res.json();
                currentDeals = Array.isArray(payload.deals) ? payload.deals : [];
                filteredDeals = [...currentDeals];
                lastSearchMeta = { origin, currency, month };

                setHeroSessionStatus({
                    lastScanText: new Date().toLocaleString([], { year: "numeric", month: "short", day: "2-digit", hour: "2-digit", minute: "2-digit" }),
                    filtersActive: countActiveFilters(),
                    modeText: "Data updated just now"
                });

                if (currentDeals.length === 0) {
                    renderEmptyDeals("No fares found in that month/budget for this origin.");
                    updateHeroKpis([], currency, true);
                    renderHeroAnalytics([], currency);
                    showToast("No deals found for that strategy.", "warning");
                    return;
                }

                applyClientFilters(true);

                if (filteredDeals.length > 0) {
                    setTimeout(() => focusDeal(origin, filteredDeals[0], currency), 150);
                }

                showToast(`Loaded ${currentDeals.length} deals.`, "success");
            } catch {
                renderEmptyDeals("Search failed or throttled. Try again with fewer max deals.");
                updateHeroKpis([], currency, true);
                renderHeroAnalytics([], currency);
                setHeroSessionStatus({
                    lastScanText: document.getElementById("heroLastScan")?.textContent || "—",
                    filtersActive: countActiveFilters(),
                    modeText: "Scan failed"
                });
                showToast("Search failed or throttled. Try lower max deals.", "warning");
            } finally {
                setScanLoading(false);
            }
}


        // --- Filtering / sorting ---
        function applyClientFilters(showToastOnApply) {
            if (!Array.isArray(currentDeals) || currentDeals.length === 0) {
                renderEmptyDeals("No deals to show.");
                updateHeroKpis([], document.getElementById("currency").value, true);
                renderHeroAnalytics(filteredDeals, document.getElementById("currency").value);

                setHeroSessionStatus({
                    lastScanText: document.getElementById("heroLastScan")?.textContent || "—",
                    filtersActive: countActiveFilters(),
                    modeText: "Filtering"
                });

                return;
            }

            const q = (document.getElementById("destSearch").value || "").trim().toLowerCase();
            const minDist = clampInt(document.getElementById("minDist").value, 0, 20000, 0);
            const maxDist = clampInt(document.getElementById("maxDist").value, 0, 20000, 4000);
            const sortBy = document.getElementById("sortBy").value;
            const hotThreshold = clampInt(document.getElementById("hotThreshold").value, 1, 99999, 40);
            const onlyHot = document.getElementById("onlyHot").checked;
            const preferWeekend = document.getElementById("preferWeekend").checked;

            const currency = document.getElementById("currency").value;

            filteredDeals = currentDeals.filter(d => {
                const dist = toNumber(d.distanceKm);
                const price = toNumber(d.price);
                if (!Number.isFinite(dist) || !Number.isFinite(price)) return false;
                if (dist < minDist || dist > maxDist) return false;
                if (onlyHot && price > hotThreshold) return false;

                if (q) {
                    const hay = [(d.destination||""),(d.destinationName||""),(d.destinationCountry||"")].join(" ").toLowerCase();
                    if (!hay.includes(q)) return false;
                }

                if (preferWeekend) {
                    const g = (new Date(d.date)).getDay();
                    if (![5,6,0].includes(g)) return false;
                }

                return true;
            });

            const sorters = {
                price: (a,b) => toNumber(a.price) - toNumber(b.price),
                ppk: (a,b) => toNumber(a.pricePerKm) - toNumber(b.pricePerKm),
                distance: (a,b) => toNumber(a.distanceKm) - toNumber(b.distanceKm),
                date: (a,b) => (new Date(a.date)) - (new Date(b.date))
            };
            filteredDeals.sort(sorters[sortBy] || sorters.price);

            redrawFromFiltered();
            renderDealsList(lastSearchMeta.origin || normalizeOriginInput(), filteredDeals, currency);
            renderAnalytics(filteredDeals, currency);
            updateHeroKpis(filteredDeals, currency, false);
            renderHeroAnalytics(filteredDeals, currency);

            if (showToastOnApply) showToast(`Applied filters: ${filteredDeals.length} deals in view.`, "info");
            persistUiToStorage();
        }

        function clearClientFilters() {
            document.getElementById("destSearch").value = "";
            document.getElementById("minDist").value = "0";
            document.getElementById("maxDist").value = "4000";
            document.getElementById("sortBy").value = "price";
            document.getElementById("hotThreshold").value = "40";
            document.getElementById("onlyHot").checked = false;
            document.getElementById("preferWeekend").checked = false;
            document.getElementById("hidePriceLabels").checked = false;
            document.getElementById("hideRoutes").checked = false;

            mapShowPriceLabels = true;
            mapShowRoutes = true;

            applyClientFilters(true);
        }

        // --- Right tab ---
        function switchRightTab(tab) {
            const deals = document.getElementById("rightDeals");
            const an = document.getElementById("rightAnalytics");
            const c1 = document.getElementById("chipViewDeals");
            const c2 = document.getElementById("chipViewAnalytics");

            if (tab === "analytics") {
                deals.style.display = "none";
                an.style.display = "block";
                c1.classList.remove("active");
                c2.classList.add("active");
            } else {
                deals.style.display = "block";
                an.style.display = "none";
                c2.classList.remove("active");
                c1.classList.add("active");
            }
        }

        // --- Map rendering ---
        function clearMap() {
            markersLayer.clearLayers();
            routesLayer.clearLayers();
            animatedLayer.clearLayers();
            stopPlaneAnimation();
        }

        function stopPlaneAnimation() {
            if (planeAnim.raf) cancelAnimationFrame(planeAnim.raf);
            planeAnim = { raf: 0, startTs: 0, duration: 0, start: null, end: null, marker: null, lastAngle: null, lastFollowTs: 0 };
        }

        function redrawFromFiltered() {
            clearMap();
            if (!filteredDeals || filteredDeals.length === 0) return;

            const origin = lastSearchMeta.origin || normalizeOriginInput();
            const currency = document.getElementById("currency").value;

            const first = filteredDeals[0];
            drawOriginMarker(first.originLat, first.originLng, origin, first.originName, first.originCountry);
            drawRoutesAndMarkers(origin, filteredDeals, currency);

            setTimeout(() => map.invalidateSize(), 100);
        }

        function drawOriginMarker(lat, lng, code, name, country) {
            lat = toNumber(lat); lng = toNumber(lng);
            if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;

            const marker = L.circleMarker([lat, lng], {
                radius: 12,
                fillColor: '#0066FF',
                color: '#FFFFFF',
                weight: 3,
                fillOpacity: 1,
                metaType: "origin"
            }).bindPopup(`
        <div style="text-align:center; padding: 8px;">
            <div style="font-size: 22px; margin-bottom: 4px;">🏠</div>
            <div style="font-weight: 600; font-size: 16px;">${escapeHtml(code)}</div>
            <div style="color:#64748B; font-size: 13px; font-weight: 600;">${escapeHtml(name || code)}</div>
            <div style="color:#64748B; font-size: 12px; font-weight: 600;">${escapeHtml(country || "")}</div>
        </div>
    `).addTo(markersLayer);

            map.setView([lat, lng], 6);
            marker.openPopup();
        }


        function drawRoutesAndMarkers(origin, deals, currency) {
            const hotThreshold = clampInt(document.getElementById("hotThreshold").value, 1, 99999, 40);

            for (let i = 0; i < deals.length; i++) {
                const deal = deals[i];

                const oLat = toNumber(deal.originLat), oLng = toNumber(deal.originLng);
                const dLat = toNumber(deal.destLat), dLng = toNumber(deal.destLng);
                if (![oLat,oLng,dLat,dLng].every(Number.isFinite)) continue;

                const price = toNumber(deal.price);
                const isHotDeal = Number.isFinite(price) && price <= hotThreshold;

                if (mapShowRoutes) {
                    L.polyline([[oLat, oLng],[dLat, dLng]], {
                        color: isHotDeal ? '#00D084' : '#0066FF',
                        weight: 2,
                        opacity: 0.42,
                        dashArray: '8, 8',
                        metaType: "deal",
                        dealIndex: i
                    }).addTo(routesLayer);
                }

                const marker = L.circleMarker([dLat, dLng], {
                    radius: isHotDeal ? 10 : 8,
                    fillColor: isHotDeal ? '#FF6B00' : '#00D084',
                    color: '#FFFFFF',
                    weight: 3,
                    fillOpacity: 0.92,
                    metaType: "deal",
                    dealIndex: i
                }).bindPopup(makeDealPopup(origin, deal, currency, isHotDeal)).addTo(markersLayer);

                if (mapShowPriceLabels) {
                    const priceIcon = L.divIcon({
                        className: 'price-label',
                        html: `${formatPrice(deal.price, currency)}`,
                        iconSize: [70, 30],
                        iconAnchor: [35, 40]
                    });

                    // tag as label so highlight logic ignores it
                    L.marker([dLat, dLng], {
                        icon: priceIcon,
                        interactive: false,
                        metaType: "label"
                    }).addTo(markersLayer);
                }

                marker.on('click', () => focusDeal(origin, deal, currency));
            }

            // If charts already selected something, re-apply highlight after redraw
            if (selectedDealIndices && selectedDealIndices.size > 0) {
                highlightSelectedDealsOnMap([...selectedDealIndices]);
            } else {
                highlightSelectedDealsOnMap([]); // reset to default look
            }
}

        function getAirport(code) {
            const c = (code || "").toString().toUpperCase().trim();
            return (c.length === 3 && airportsIndex && airportsIndex[c]) ? airportsIndex[c] : null;
        }

        function airportLabel(code, fallbackName) {
            const c = (code || "").toString().toUpperCase().trim();
            if (!c) return "";
            const a = getAirport(c);
            const name = (fallbackName || a?.name || "").toString().trim();
            return name ? `${name} (${c})` : c;
        }

        function formatDurationMinutes(mins) {
            const m = Math.max(0, Math.round(mins));
            const h = Math.floor(m / 60);
            const r = m % 60;
            if (h <= 0) return `${r}m`;
            if (r === 0) return `${h}h`;
            return `${h}h ${r}m`;
        }

        // Estimated block time (NOT schedule): taxi + climb/desc + cruise
        function estimateFlightDurationLabel(distanceKm) {
            const km = toNumber(distanceKm);
            if (!Number.isFinite(km) || km <= 0) return "";
            const cruiseKmh = km < 600 ? 650 : 800;
            const minutes = 40 + (km / cruiseKmh) * 60;     // 40 min overhead + cruise
            const rounded = Math.round(minutes / 5) * 5;    // round to 5 minutes
            return `~${formatDurationMinutes(rounded)}`;
        }




        function makeDealPopup(origin, deal, currency, isHotDeal) {
            const originInfo = getAirport(origin);
            const originPretty = airportLabel(origin, originInfo?.name);

            const destCode = (deal.destination || "").toString().toUpperCase();
            const destPretty = airportLabel(destCode, deal.destinationName);

            const dur = estimateFlightDurationLabel(deal.distanceKm);

            return `
        <div style="text-align:center; padding: 10px; min-width: 220px;">
            <div style="font-size: 28px; margin-bottom: 6px;">${isHotDeal ? '🔥' : '✈️'}</div>
            <div style="font-weight: 600; font-size: 16px;">
                ${escapeHtml(originPretty)} → ${escapeHtml(destPretty)}
            </div>
            <div style="font-size: 20px; font-weight: 600; color: #00D084; margin: 8px 0;">
                ${formatPrice(deal.price, currency)}
            </div>
            <div style="color:#64748B; font-size: 12px; font-weight: 600;">
                 📅 ${escapeHtml(formatDate(deal.date))}
                ${formatTimeRange(deal) ? ` · 🕒 ${escapeHtml(formatTimeRange(deal))}` : ``}
                ${dur ? ` · ⏱️ ${escapeHtml(dur)}` : ``}
                · 🛫 ${escapeHtml(String(deal.distanceKm))} km

            </div>
            <div style="color:#64748B; font-size: 12px; font-weight: 600; margin-top:4px;">
                📏 ${escapeHtml(formatPerKm(deal.pricePerKm, currency))}
            </div>
        </div>
    `;
        }


        // --- Deals list ---
        function renderEmptyDeals(msg) {
            document.getElementById('dealsList').innerHTML = `
                <div style="text-align:center; padding: 26px; color: #64748B; font-weight: 600;">
                    ${escapeHtml(msg || "No deals to show.")}
                </div>
            `;
        }

        function renderDealsList(origin, deals, currency) {
            const list = document.getElementById('dealsList');
            list.innerHTML = '';

            if (!deals || deals.length === 0) {
                renderEmptyDeals("No deals match your filters.");
                return;
            }

            const hotThreshold = clampInt(document.getElementById("hotThreshold").value, 1, 99999, 40);

            // origin label with name + code if available
            const originInfo = getAirport(origin);
            const originPretty = airportLabel(origin, originInfo?.name);

            for (const deal of deals) {
                const price = toNumber(deal.price);
                const isHotDeal = Number.isFinite(price) && price <= hotThreshold;
                const key = dealKey(deal);

                const destCode = (deal.destination || "").toString().toUpperCase();
                const destPretty = airportLabel(destCode, deal.destinationName);

                const destCountry = (deal.destinationCountry || getAirport(destCode)?.country || "").toString().trim();
                const dur = estimateFlightDurationLabel(deal.distanceKm);

                const item = document.createElement('div');
                item.className = 'deal-item' + (key === selectedDealKey ? ' selected' : '');

                item.innerHTML = `
            <div class="deal-head">
                <div class="deal-route">
                    ${escapeHtml(originPretty)} → ${escapeHtml(destPretty)}
                    ${isHotDeal ? `<span class="badge-hot">HOT</span>` : ``}
                </div>
                <div class="deal-price">${formatPrice(deal.price, currency)}</div>
            </div>

                        <div class="deal-meta">
                <span>📅 ${escapeHtml(formatDate(deal.date))}</span>
                ${formatTimeRange(deal) ? `<span>🕒 ${escapeHtml(formatTimeRange(deal))}</span>` : ``}
                ${dur ? `<span>⏱️ ${escapeHtml(dur)}</span>` : ``}
                ${destCountry ? `<span>🌍 ${escapeHtml(destCountry)}</span>` : ``}
                <span>🛫 ${escapeHtml(String(deal.distanceKm))} km</span>
                <span>📏 ${escapeHtml(formatPerKm(deal.pricePerKm, currency))}</span>
            </div>

        `;

                item.onclick = () => focusDeal(origin, deal, currency);
                list.appendChild(item);
            }
}


        // --- Focus + plane animation (rotation fixed) ---
        function focusDeal(origin, deal, currency) {
            const oLat = toNumber(deal.originLat), oLng = toNumber(deal.originLng);
            const dLat = toNumber(deal.destLat), dLng = toNumber(deal.destLng);
            if (![oLat,oLng,dLat,dLng].every(Number.isFinite)) return;

            selectedDealKey = dealKey(deal);
            renderDealsList(origin, filteredDeals, currency);

            animatedLayer.clearLayers();
            stopPlaneAnimation();

            const line = L.polyline([[oLat,oLng],[dLat,dLng]], {
                color: '#0066FF', weight: 4, opacity: 0.85, dashArray: '12, 12'
            }).addTo(animatedLayer);

            const planeMarker = L.marker([oLat, oLng], { icon: makePlaneIcon() }).addTo(animatedLayer);
            setTimeout(() => rotatePlaneMarker(planeMarker, bearingDeg(oLat, oLng, dLat, dLng)), 0);
            animatePlaneSmooth(planeMarker, {lat:oLat, lng:oLng}, {lat:dLat, lng:dLng}, deal.distanceKm);

            if (uiState.autoZoom) map.fitBounds(line.getBounds(), { padding: [80, 80] });
        }

        function makePlaneIcon() {
            return L.divIcon({
                className: 'plane-marker',
                html: `<span class="plane-inner">✈️</span>`,
                iconSize: [30, 30],
                iconAnchor: [15, 15]
            });
        }

        function rotatePlaneMarker(marker, angleDeg) {
            const el = marker.getElement();
            if (!el) return;

            const inner = el.querySelector(".plane-inner");
            if (!inner) return;

            // Emoji plane points ~45° off by default → compensate
            const EMOJI_OFFSET = -45;

            inner.style.transform = `rotate(${angleDeg + EMOJI_OFFSET}deg)`;
        }


        function animatePlaneSmooth(marker, start, end, distanceKm) {
            const dist = clamp(toNumber(distanceKm), 120, 5200, 900);
            const duration = clamp(900 + dist * 1.0, 1100, 5200, 2500);

            planeAnim.marker = marker;
            planeAnim.start = start;
            planeAnim.end = end;
            planeAnim.duration = duration;
            planeAnim.startTs = 0;
            planeAnim.lastAngle = null;
            planeAnim.lastFollowTs = 0;

            const step = (ts) => {
                if (!planeAnim.startTs) planeAnim.startTs = ts;

                const t = clamp((ts - planeAnim.startTs) / planeAnim.duration, 0, 1, 0);
                const p = easeInOutCubic(t);

                const lat = start.lat + (end.lat - start.lat) * p;
                const lng = start.lng + (end.lng - start.lng) * p;
                marker.setLatLng([lat, lng]);

                const look = clamp(p + 0.015, 0, 1, 1);
                const lat2 = start.lat + (end.lat - start.lat) * look;
                const lng2 = start.lng + (end.lng - start.lng) * look;
                const ang = bearingDeg(lat, lng, lat2, lng2);

                if (planeAnim.lastAngle === null || Math.abs(ang - planeAnim.lastAngle) > 1.2) {
                    rotatePlaneMarker(marker, ang);
                    planeAnim.lastAngle = ang;
                }

                if (uiState.followPlane) {
                    if (!planeAnim.lastFollowTs || (ts - planeAnim.lastFollowTs) > 120) {
                        map.setView([lat, lng], map.getZoom(), { animate: false });
                        planeAnim.lastFollowTs = ts;
                    }
                }

                if (t < 1) {
                    planeAnim.raf = requestAnimationFrame(step);
                } else {
                    planeAnim.raf = 0;
                }
            };

            planeAnim.raf = requestAnimationFrame(step);
        }


        function toggleFollow() { uiState.followPlane = !uiState.followPlane; updateMapToggleUi(); persistUiToStorage(); }
        function toggleAutoZoom() { uiState.autoZoom = !uiState.autoZoom; updateMapToggleUi(); persistUiToStorage(); }

        function updateMapToggleUi() {
            document.getElementById("toggleFollow").classList.toggle("active", !!uiState.followPlane);
            document.getElementById("toggleAutoZoom").classList.toggle("active", !!uiState.autoZoom);
            applyMapSizeClass();
        }

        // --- Analytics + KPIs ---
        function renderAnalytics(deals, currency) {
            deals = Array.isArray(deals) ? deals : [];

            // ---- Helpers (local) ----
            const num = (x) => toNumber(x);
            const fmtP = (x) => formatPrice(x, currency);
            const fmtPpk = (x) => formatPerKm(x, currency);

            function quantileSorted(sorted, q) {
                if (!sorted.length) return NaN;
                const pos = (sorted.length - 1) * q;
                const base = Math.floor(pos);
                const rest = pos - base;
                if (sorted[base + 1] === undefined) return sorted[base];
                return sorted[base] + rest * (sorted[base + 1] - sorted[base]);
            }

            function dealDayKey(d) {
                // Works for "YYYY-MM-DD" and ISO strings
                const s = (d?.date || "").toString();
                return s.length >= 10 ? s.slice(0, 10) : s;
            }

            function monthLabel(ym) {
                // ym: "YYYY-MM"
                if (!ym || ym.length < 7) return "–";
                const y = parseInt(ym.slice(0, 4), 10);
                const m = parseInt(ym.slice(5, 7), 10) - 1;
                const dt = new Date(y, m, 1);
                if (isNaN(dt.getTime())) return ym;
                return dt.toLocaleDateString([], { year: "numeric", month: "long" });
            }

            function selectDealFromAnalytics(deal) {
                if (!deal) return;

                // Map highlighting expects indices aligned to the last redrawFromFiltered() order (filteredDeals)
                const idx = Array.isArray(filteredDeals)
                    ? filteredDeals.findIndex(d => dealKey(d) === dealKey(deal))
                    : -1;

                if (idx >= 0) {
                    selectedDealIndices = new Set([idx]);
                    highlightSelectedDealsOnMap([idx]);
                }

                const origin = lastSearchMeta.origin || normalizeOriginInput();
                focusDeal(origin, deal, currency);
            }

            // ---- Empty state ----
            const pricesSorted = deals.map(d => num(d.price)).filter(Number.isFinite).sort((a, b) => a - b);
            const ppksSorted = deals.map(d => num(d.pricePerKm)).filter(Number.isFinite).sort((a, b) => a - b);

            if (!pricesSorted.length) {
                drawSpark([]);
                setText("mAverage", "–"); setText("mAverageS", "–");
                setText("mMedian", "–"); setText("mMedianS", "Typical price");
                setText("mDealsInView", "0"); setText("mDealsInViewS", "matching filters");

                setText("mOverBudget", "–"); setText("mOverBudgetS", "–");
                setText("mSpread", "–"); setText("mBand", "–");
                setText("mBestPpk", "–"); setText("mBestPpkS", "–");
                setText("mCheapest", "–"); setText("mCheapestS", "–");

                setText("mBudgetHit", "–");
                setText("mDaysCovered", "–");
                setText("mBestDow", "–");
                setText("mTopCountry", "–");
                setText("mInsightNote", "Scan deals to unlock analytics.");

                const grid = document.getElementById("calGrid");
                if (grid) grid.innerHTML = "";
                setText("calMonthLabel", monthLabel(lastSearchMeta?.month || document.getElementById("month")?.value));
                const det = document.getElementById("calDetail");
                if (det) det.innerHTML = `<div class="t">Pick a day</div><div class="s">You’ll see the cheapest route for that date here.</div>`;
                return;
            }

            // ---- Core stats ----
            const avg = mean(pricesSorted);
            const med = median(pricesSorted);
            const cheapest = pricesSorted[0];

            const p10 = quantileSorted(pricesSorted, 0.10);
            const p25 = quantileSorted(pricesSorted, 0.25);
            const p75 = quantileSorted(pricesSorted, 0.75);
            const p90 = quantileSorted(pricesSorted, 0.90);

            setText("mAverage", fmtP(avg));
            setText("mAverageS", `${deals.length} deals in view`);
            setText("mMedian", fmtP(med));
            setText("mMedianS", "Typical price");

            setText("mDealsInView", `${deals.length}`);
            setText("mDealsInViewS", "matching filters");

            setText("mCheapest", fmtP(cheapest));
            // show cheapest deal route label (destination)
            const cheapestDeal = deals.reduce((acc, d) => (num(d.price) < num(acc.price) ? d : acc), deals[0]);
            setText("mCheapestS", cheapestDeal?.destination ? `${cheapestDeal.destination}` : "–");

            if (ppksSorted.length) {
                const bestPpk = ppksSorted[0];
                const bestDeal = deals.reduce((acc, d) => (num(d.pricePerKm) < num(acc.pricePerKm) ? d : acc), deals[0]);
                setText("mBestPpk", fmtPpk(bestPpk));
                setText("mBestPpkS", `${bestDeal?.destination || "–"} · ${bestDeal?.distanceKm || "–"} km`);
            } else {
                setText("mBestPpk", "–");
                setText("mBestPpkS", "–");
            }

            setText("mSpread", `${fmtP(p10)} – ${fmtP(p90)}`);
            setText("mBand", `${fmtP(p25)} – ${fmtP(p75)}`);

            // ---- Budget compliance ----
            const budget = clampInt(document.getElementById("maxBudget")?.value, 1, 99999, NaN);
            const over = Number.isFinite(budget) ? deals.filter(d => num(d.price) > budget).length : 0;
            const under = Number.isFinite(budget) ? deals.filter(d => num(d.price) <= budget).length : deals.length;
            const hitRate = Number.isFinite(budget) ? (under / Math.max(1, deals.length)) : NaN;

            setText("mOverBudget", Number.isFinite(budget) ? `${over}` : "–");
            setText("mOverBudgetS", Number.isFinite(budget) ? `>${fmtP(budget)} limit` : "set a budget");
            setText("mBudgetHit", Number.isFinite(budget) ? `${Math.round(hitRate * 100)}% (${under}/${deals.length})` : "–");

            // ---- Best weekday (by avg price) ----
            const dowAgg = {};
            for (const d of deals) {
                const p = num(d.price); if (!Number.isFinite(p)) continue;
                const dow = (new Date(d.date)).getDay();
                dowAgg[dow] = dowAgg[dow] || { sum: 0, count: 0 };
                dowAgg[dow].sum += p; dowAgg[dow].count++;
            }
            let bestDow = null, bestDowAvg = Infinity;
            for (const k in dowAgg) {
                const v = dowAgg[k];
                const a = v.sum / Math.max(1, v.count);
                if (a < bestDowAvg) { bestDowAvg = a; bestDow = parseInt(k, 10); }
            }
            setText("mBestDow", bestDow === null ? "–" : `${dowName(bestDow)} (${fmtP(bestDowAvg)} avg)`);

            // ---- Top destination country ----
            const countryAgg = {};
            for (const d of deals) {
                const c = (d.destinationCountry || "").toString().trim();
                if (!c) continue;
                countryAgg[c] = (countryAgg[c] || 0) + 1;
            }
            const top = Object.entries(countryAgg).sort((a, b) => b[1] - a[1])[0];
            setText("mTopCountry", top ? `${top[0]} (${top[1]})` : "–");

            // ---- Daily cheapest series + calendar ----
            const ym = lastSearchMeta?.month || document.getElementById("month")?.value || "";
            setText("calMonthLabel", monthLabel(ym));

            // Map of YYYY-MM-DD -> cheapest deal that day (within current filtered view)
            const byDay = {};
            for (const d of deals) {
                const day = dealDayKey(d);
                const p = num(d.price);
                if (!day || !Number.isFinite(p)) continue;
                if (!byDay[day] || p < num(byDay[day].price)) byDay[day] = d;
            }

            // Spark: daily cheapest values sorted by date
            const dailyKeys = Object.keys(byDay).sort((a, b) => new Date(a) - new Date(b));
            const dailyMinSeries = dailyKeys.map(k => num(byDay[k].price)).filter(Number.isFinite);
            drawSpark(dailyMinSeries);

            // Calendar build (month grid)
            const grid = document.getElementById("calGrid");
            const det = document.getElementById("calDetail");
            if (grid) {
                grid.innerHTML = "";

                // Determine month range
                let y = 0, m = 0;
                if (ym && ym.length >= 7) {
                    y = parseInt(ym.slice(0, 4), 10);
                    m = parseInt(ym.slice(5, 7), 10) - 1;
                } else {
                    const firstDealDate = new Date(deals[0].date);
                    y = firstDealDate.getFullYear();
                    m = firstDealDate.getMonth();
                }

                const first = new Date(y, m, 1);
                const last = new Date(y, m + 1, 0);
                const daysInMonth = last.getDate();

                // Monday-first offset
                const jsDow = first.getDay(); // Sun=0
                const offset = (jsDow + 6) % 7; // Mon=0

                // Month-best day (for highlight)
                let monthBestKey = null;
                let monthBestPrice = Infinity;
                for (const k of Object.keys(byDay)) {
                    const dt = new Date(k);
                    if (dt.getFullYear() !== y || dt.getMonth() !== m) continue;
                    const p = num(byDay[k].price);
                    if (Number.isFinite(p) && p < monthBestPrice) { monthBestPrice = p; monthBestKey = k; }
                }

                // leading empties
                for (let i = 0; i < offset; i++) {
                    const cell = document.createElement("div");
                    cell.className = "cal-cell empty";
                    grid.appendChild(cell);
                }

                // day cells
                for (let dayNum = 1; dayNum <= daysInMonth; dayNum++) {
                    const dt = new Date(y, m, dayNum);
                    const key = dt.toISOString().slice(0, 10);

                    const deal = byDay[key];
                    const cell = document.createElement("div");

                    const has = !!deal;
                    cell.className = "cal-cell" + (has ? " has" : "") + (monthBestKey === key ? " best" : "");

                    if (!has) {
                        cell.innerHTML = `<div class="cal-day">${dayNum}</div>`;
                    } else {
                        const dest = (deal.destination || "").toString().toUpperCase();
                        cell.innerHTML = `
          <div class="cal-day">${dayNum}</div>
          <div class="cal-price">${fmtP(deal.price)}</div>
          <div class="cal-route">${escapeHtml(dest)}</div>
        `;

                        cell.title = `${formatDate(deal.date)} · ${dest} · ${fmtP(deal.price)}`;
                        cell.addEventListener("click", () => {
                            // focus + map highlight
                            selectDealFromAnalytics(deal);

                            if (det) {
                                const origin = lastSearchMeta.origin || normalizeOriginInput();
                                const destCode = (deal.destination || "").toString().toUpperCase();
                                const originInfo = getAirport(origin);
                                const originPretty = airportLabel(origin, originInfo?.name);
                                const destPretty = airportLabel(destCode, deal.destinationName);
                                const dur = estimateFlightDurationLabel(deal.distanceKm);

                                det.innerHTML = `
              <div class="t">${escapeHtml(formatDate(deal.date))} · ${escapeHtml(originPretty)} → ${escapeHtml(destPretty)}</div>
              <div class="s">
                ${escapeHtml(fmtP(deal.price))} · ${escapeHtml(formatPerKm(deal.pricePerKm, currency))}
                ${formatTimeRange(deal) ? ` · 🕒 ${escapeHtml(formatTimeRange(deal))}` : ``}
                ${dur ? ` · ⏱️ ${escapeHtml(dur)}` : ``}
                · 🛫 ${escapeHtml(String(deal.distanceKm))} km
              </div>
            `;
                            }
                        });
                    }

                    grid.appendChild(cell);
                }
            }

            // Days covered
            const coveredDays = Object.keys(byDay).filter(k => {
                const dt = new Date(k);
                return dt.getFullYear() === (new Date(deals[0].date)).getFullYear() && true;
            }).length;
            setText("mDaysCovered", `${coveredDays} day(s) with deals`);

            // A short “what to do” insight (not fluff)
            const hotThreshold = clampInt(document.getElementById("hotThreshold")?.value, 1, 99999, 40);
            const hotCount = deals.filter(d => num(d.price) <= hotThreshold).length;

            const iqr = (Number.isFinite(p75) && Number.isFinite(p25)) ? (p75 - p25) : NaN;
            const noteParts = [];
            if (Number.isFinite(budget)) {
                noteParts.push(`${under} under ${fmtP(budget)} (${Math.round(hitRate * 100)}% hit-rate).`);
            }
            noteParts.push(`${hotCount} hot ≤ ${fmtP(hotThreshold)}.`);
            if (Number.isFinite(iqr)) {
                noteParts.push(`Typical variability (IQR): ${fmtP(iqr)}.`);
            }
            noteParts.push(`Use the calendar to pick the cheapest day, then click to lock it on the map.`);

            setText("mInsightNote", noteParts.join(" "));
        }


        function updateHeroKpis(deals, currency, immediate) {
            const hotThreshold = clampInt(document.getElementById("hotThreshold").value, 1, 99999, 40);

            const prices = (deals || []).map(d => toNumber(d.price)).filter(Number.isFinite).sort((a,b)=>a-b);
            const ppks = (deals || []).map(d => toNumber(d.pricePerKm)).filter(Number.isFinite).sort((a,b)=>a-b);

            const target = {
                deals: (deals || []).length,
                hot: (deals || []).filter(d => toNumber(d.price) <= hotThreshold).length,
                cheapest: prices.length ? prices[0] : null,
                bestPpk: ppks.length ? ppks[0] : null,
                currency
            };

            if (immediate) {
                kpiState.deals = target.deals;
                kpiState.hot = target.hot;
                kpiState.cheapest = target.cheapest;
                kpiState.bestPpk = target.bestPpk;
                kpiState.currency = currency;
                paintHeroKpis();
                return;
            }

            animateNumber("kpiDeals", kpiState.deals, target.deals, 450, v => `${Math.round(v)}`);
            animateNumber("kpiHot", kpiState.hot, target.hot, 450, v => `${Math.round(v)}`);

            // Cheapest / BestPpk: animate by quick crossfade-ish update
            setText("kpiCheapest", target.cheapest == null ? "–" : formatPrice(target.cheapest, currency));
            setText("kpiBestPpk", target.bestPpk == null ? "–" : formatPerKm(target.bestPpk, currency));

            setText("kpiCheapestSub", target.cheapest == null ? "best price" : "cheapest in view");
            setText("kpiBestPpkSub", target.bestPpk == null ? "efficiency" : "best €/km");

            kpiState.deals = target.deals;
            kpiState.hot = target.hot;
            kpiState.cheapest = target.cheapest;
            kpiState.bestPpk = target.bestPpk;
            kpiState.currency = currency;
        }

        function paintHeroKpis() {
            setText("kpiDeals", `${kpiState.deals}`);
            setText("kpiHot", `${kpiState.hot}`);
            setText("kpiCheapest", kpiState.cheapest == null ? "–" : formatPrice(kpiState.cheapest, kpiState.currency));
            setText("kpiBestPpk", kpiState.bestPpk == null ? "–" : formatPerKm(kpiState.bestPpk, kpiState.currency));
        }

        function animateNumber(id, from, to, ms, fmt) {
            const el = document.getElementById(id);
            if (!el) return;
            const start = performance.now();
            const f = Number(from) || 0;
            const t = Number(to) || 0;

            const step = (now) => {
                const p = clamp((now - start) / ms, 0, 1, 1);
                const e = easeInOutCubic(p);
                const v = f + (t - f) * e;
                el.textContent = (fmt ? fmt(v) : `${v}`);
                if (p < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
        }

        function drawSpark(values) {
            const canvas = document.getElementById("sparkCanvas");
            const ctx = canvas.getContext("2d");
            const w = canvas.width, h = canvas.height;
            ctx.clearRect(0,0,w,h);

            if (!values || values.length < 2) {
                ctx.beginPath();
                ctx.lineWidth = 3;
                ctx.strokeStyle = "rgba(0,102,255,0.35)";
                ctx.moveTo(20, h/2);
                ctx.lineTo(w-20, h/2);
                ctx.stroke();
                return;
            }

            const minV = Math.min(...values);
            const maxV = Math.max(...values);
            const padX = 20, padY = 18;
            const innerW = w - padX*2;
            const innerH = h - padY*2;
            const denom = (maxV - minV) || 1;

            ctx.lineWidth = 4;
            ctx.strokeStyle = "rgba(0,102,255,0.75)";
            ctx.beginPath();
            for (let i=0;i<values.length;i++) {
                const x = padX + (innerW * (i/(values.length-1)));
                const y = padY + (innerH * (1 - ((values[i]-minV)/denom)));
                if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
            }
            ctx.stroke();
        }

        // --- CSV export (filtered view) ---
        function exportCsv() {
            const deals = filteredDeals || [];
            if (!deals.length) {
                showToast("No deals to export.", "info");
                return;
            }

            const currency = document.getElementById("currency").value;
            const origin = lastSearchMeta.origin || normalizeOriginInput();

            const headers = [
                "origin","destination","date","departureTime","arrivalTime","price","currency","distanceKm","pricePerKm",
                "destinationName","destinationCountry","originLat","originLng","destLat","destLng"
            ];


            const rows = deals.map(d => ([
                origin,
                safeCsv(d.destination),
                safeCsv(d.date),
                safeCsv(d.departureTime),
                safeCsv(d.arrivalTime),
                numCsv(d.price),
                currency,
                numCsv(d.distanceKm),
                numCsv(d.pricePerKm),
                safeCsv(d.destinationName),
                safeCsv(d.destinationCountry),
                numCsv(d.originLat), numCsv(d.originLng),
                numCsv(d.destLat), numCsv(d.destLng)
            ]));


            const csv = [headers.join(","), ...rows.map(r => r.join(","))].join("\n");

            const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
            const a = document.createElement("a");
            const url = URL.createObjectURL(blob);
            a.href = url;
            a.download = `socialstrats_deals_${origin}_${(lastSearchMeta.month || "").replace("-","")}.csv`;
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);

            showToast("CSV exported.", "success");
        }

        function safeCsv(s) {
            const v = (s ?? "").toString().replaceAll('"','""');
            return `"${v}"`;
        }
        function numCsv(n) {
            const v = toNumber(n);
            return Number.isFinite(v) ? `${v}` : "";
        }

        // --- Share / Reset ---
        async function copyShareLink() {
            try {
                await navigator.clipboard.writeText(window.location.href);
                showToast("Share link copied.", "success");
            } catch {
                showToast("Copy failed. Please copy URL from the address bar.", "warning");
            }
        }

        function resetApp() {
            clearMap();
            currentDeals = [];
            filteredDeals = [];
            selectedDealKey = null;
            renderEmptyDeals("Reset complete.");
            renderAnalytics([], document.getElementById("currency").value);
            updateHeroKpis([], document.getElementById("currency").value, true);
            showToast("Reset complete.", "info");
        }

        // --- UI helpers ---
        function showToast(message, type = "info") {
            const container = document.getElementById("toastContainer");
            const toast = document.createElement("div");
            toast.className = "toast";

            const icon = type === "success" ? "✅" : (type === "warning" ? "⚠️" : "ℹ️");
            toast.innerHTML = `<div class="icon">${icon}</div><div class="msg">${escapeHtml(message)}</div>`;
            container.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = "0";
                toast.style.transform = "translateX(420px)";
                toast.style.transition = "all .22s ease";
                setTimeout(() => toast.remove(), 240);
            }, 3200);
        }

        // --- Small utils ---
        function normalizeOriginInput() {
            const raw = (document.getElementById("origin").value || "").trim();
            return raw.length >= 3 ? raw.substring(0,3).toUpperCase() : raw.toUpperCase();
        }

        function dealKey(d) { return `${d.destination||""}|${d.date||""}|${d.price||""}`.toLowerCase(); }

        function escapeHtml(s) {
            return (s || "").toString()
                .replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;")
                .replaceAll('"',"&quot;").replaceAll("'","&#039;");
        }

        function currencySymbol(currency) {
            const symbols = { EUR:"€", GBP:"£", USD:"$" };
            return symbols[currency] || "€";
        }

        function formatPrice(price, currency) {
            const p = toNumber(price);
            if (!Number.isFinite(p)) return `${currencySymbol(currency)}–`;
            return `${currencySymbol(currency)}${p.toFixed(2)}`;
        }

        function formatPerKm(ppk, currency) {
            const v = toNumber(ppk);
            if (!Number.isFinite(v)) return `${currencySymbol(currency)}–/km`;
            return `${currencySymbol(currency)}${v.toFixed(4)}/km`;
        }

        function formatDate(dateStr) {
            const date = new Date(dateStr);
            if (isNaN(date.getTime())) return dateStr;
            return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }
        function formatTimeOnly(isoOrTime) {
            if (!isoOrTime) return "";
            const s = String(isoOrTime);

            // If API gives plain "HH:mm" (or "HH:mm:ss"), keep it stable
            const m = s.match(/^(\d{2}):(\d{2})(?::\d{2})?$/);
            if (m) return `${m[1]}:${m[2]}`;

            // Otherwise try ISO date parsing
            const d = new Date(s);
            if (isNaN(d.getTime())) return "";
            return d.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
        }

        function formatTimeRange(deal) {
            const dep = formatTimeOnly(deal.departureTime);
            const arr = formatTimeOnly(deal.arrivalTime);
            if (dep && arr) return `${dep} → ${arr}`;
            if (dep) return dep;
            return "";
        }



        function toNumber(x) { const n = Number(x); return Number.isFinite(n) ? n : NaN; }
        function clamp(n, min, max, fallback) { n = Number(n); if (!Number.isFinite(n)) return fallback; return Math.max(min, Math.min(max, n)); }
        function clampInt(v, min, max, fallback) { const n = parseInt(v, 10); if (!Number.isFinite(n)) return fallback; return Math.max(min, Math.min(max, n)); }

        function mean(arr){ return arr.reduce((a,b)=>a+b,0)/Math.max(1,arr.length); }
        function median(arr){
            if (!arr.length) return NaN;
            const a=[...arr].sort((x,y)=>x-y);
            const m=Math.floor(a.length/2);
            return a.length%2 ? a[m] : (a[m-1]+a[m])/2;
        }

        function dowName(d){ return ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"][d] || "–"; }

        function bearingDeg(lat1, lon1, lat2, lon2) {
            const toRad = d => d * Math.PI / 180.0;
            const toDeg = r => r * 180.0 / Math.PI;
            const φ1 = toRad(lat1), φ2 = toRad(lat2);
            const Δλ = toRad(lon2 - lon1);
            const y = Math.sin(Δλ) * Math.cos(φ2);
            const x = Math.cos(φ1) * Math.sin(φ2) - Math.sin(φ1) * Math.cos(φ2) * Math.cos(Δλ);
            let θ = Math.atan2(y, x);
            θ = (toDeg(θ) + 360) % 360;
            return θ;
        }

        function easeInOutCubic(t){ return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t + 2, 3)/2; }
        function debounce(fn, ms){ let t=0; return (...args)=>{ clearTimeout(t); t=setTimeout(()=>fn(...args), ms); }; }
        function setText(id, value){ const el=document.getElementById(id); if(el) el.textContent=value; }
        // =========================
        // HERO v2 micro-interactions + status
        // =========================
        (function heroV2Init() {
            const hero = document.getElementById("heroCard");
            if (!hero) return;
            // Public helper to update hero strip (call from scanDeals/applyClientFilters)
            window.setHeroSessionStatus = function setHeroSessionStatus({ lastScanText, filtersActive, modeText }) {
                const last = document.getElementById("heroLastScan");
                const f = document.getElementById("heroFilters");
                const mode = document.getElementById("heroStatusPill");
                if (last && lastScanText) last.textContent = lastScanText;
                if (f && Number.isFinite(filtersActive)) f.textContent = `${filtersActive} active`;
                if (mode && modeText) mode.textContent = modeText;
            };
        })();

        function countActiveFilters() {
            let n = 0;
            const q = (document.getElementById("destSearch").value || "").trim();
            const minDist = (document.getElementById("minDist").value || "0").trim();
            const maxDist = (document.getElementById("maxDist").value || "4000").trim();
            const sortBy = (document.getElementById("sortBy").value || "price");
            const hot = (document.getElementById("hotThreshold").value || "40").trim();

            if (q) n++;
            if (minDist !== "0") n++;
            if (maxDist !== "4000") n++;
            if (sortBy !== "price") n++;
            if (hot !== "40") n++;

            if (document.getElementById("onlyHot").checked) n++;
            if (document.getElementById("preferWeekend").checked) n++;
            if (document.getElementById("hidePriceLabels").checked) n++;
            if (document.getElementById("hideRoutes").checked) n++;

            return n;
        }
        (() => {
            const words = document.querySelectorAll('.hero-rotator-word');
            if (!words.length) return;

            let i = 0;
            setInterval(() => {
                words[i].classList.remove('active');
                i = (i + 1) % words.length;
                words[i].classList.add('active');
            }, 2200);
        })();


    </script>
    
