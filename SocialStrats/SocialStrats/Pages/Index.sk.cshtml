        function bindAdvancedUI() {
            const watchIds = ["destSearch", "minDist", "maxDist", "sortBy", "hotThreshold", "onlyHot", "preferWeekend", "hidePriceLabels", "hideRoutes"];
            for (const id of watchIds) {
                const el = document.getElementById(id);
