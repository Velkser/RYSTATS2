        /* =========================
   PRIMARY HERO CTA (MAIN BUTTON)
   ========================= */

        .btn-ss-cta{
            padding: 16px 26px;
            font-size: 16px;
            font-weight: 600;
            letter-spacing: -0.2px;
            border-radius: 22px;
            min-height: 56px;

            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;

            box-shadow:
                0 14px 34px rgba(0,102,255,0.35),
                inset 0 1px 0 rgba(255,255,255,0.35);

            position: relative;
            isolation: isolate;

            /* idle "breathing" animation */
            animation: ctaIdle 2.8s ease-in-out infinite;
        }

        /* stop idle pulse on interaction */
        .btn-ss-cta:hover,
        .btn-ss-cta:active{
            animation: none;
        }

        /* text */
        .btn-ss-cta .cta-label{
            position: relative;
            z-index: 2;
        }

        /* hover — magnetic lift */
        .btn-ss-cta:hover{
            transform: translateY(-2px) scale(1.02);
            box-shadow:
                0 22px 46px rgba(0,102,255,0.45),
                inset 0 1px 0 rgba(255,255,255,0.45);
        }

        /* active — tactile press */
        .btn-ss-cta:active{
            transform: translateY(0) scale(0.98);
            box-shadow:
                0 10px 20px rgba(0,102,255,0.30),
                inset 0 2px 6px rgba(0,0,0,0.20);
        }

        /* subtle breathing glow */
        @@keyframes ctaIdle{
            0%{
                box-shadow:
                    0 14px 34px rgba(0,102,255,0.30),
                    inset 0 1px 0 rgba(255,255,255,0.35);
            }
            50%{
                box-shadow:
                    0 18px 42px rgba(0,102,255,0.45),
                    inset 0 1px 0 rgba(255,255,255,0.45);
            }
            100%{
                box-shadow:
                    0 14px 34px rgba(0,102,255,0.30),
