        .an-title{ font-weight: 700; font-size: 12px; letter-spacing: .2px; }
        .an-sub{ color: var(--muted); font-weight: 600; font-size: 12px; margin-top: 4px; }

        .an-spark{
            width:100%;
            height:72px;
            margin-top: 10px;
            border-radius: 14px;
            border: 1px solid rgba(0,0,0,0.10);
            background: linear-gradient(135deg, rgba(0,102,255,0.06), rgba(255,107,0,0.05));
        }

        .an-kpis{
            display:grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin: 12px 0;
        }
        .an-kpi{
            border: 1px solid rgba(0,0,0,0.10);
            border-radius: 18px;
            padding: 12px;
            background: #fff;
        }
        .an-kpi .k{ color: var(--muted); font-weight: 700; font-size: 11px; }
        .an-kpi .v{ font-weight: 800; font-size: 18px; margin-top: 4px; letter-spacing: -0.2px; }
        .an-kpi .s{ color: var(--muted); font-weight: 600; font-size: 12px; margin-top: 2px; }

        .an-split{
            display:grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }


        .an-cal-head{
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap: 10px;
            margin-top: 10px;
        }
        .cal-month{ font-weight: 800; font-size: 13px; }
        .cal-legend{ color: var(--muted); font-weight: 700; font-size: 11px; display:flex; gap: 10px; align-items:center; }
        .dot{ width:10px; height:10px; border-radius: 999px; display:inline-block; border: 2px solid rgba(0,0,0,0.18); }
        .dot-has{ background: rgba(0,208,132,0.25); border-color: rgba(0,208,132,0.55); }
        .dot-best{ background: rgba(255,107,0,0.25); border-color: rgba(255,107,0,0.65); }

        .cal-dow{
            display:grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
            margin-top: 10px;
            color: var(--muted);
            font-weight: 800;
            font-size: 11px;
        }
        .cal-dow span{ text-align:center; }

        .cal-grid{
            display:grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
            margin-top: 8px;
        }
        .cal-cell{
            border: 1px solid rgba(0,0,0,0.10);
            border-radius: 14px;
            padding: 8px 8px 7px;
            background: #fff;
            min-height: 56px;
            cursor: default;
            transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
            position: relative;
            overflow: hidden;
        }
        .cal-cell:hover{
            transform: translateY(-1px);
            box-shadow: 0 10px 22px rgba(15,23,42,0.10);
        }
        .cal-cell.empty{ background: rgba(255,255,255,0.45); border-style: dashed; cursor: default; }
        .cal-cell.has{ cursor:pointer; border-color: rgba(0,208,132,0.35); }
        .cal-cell.best{ border-color: rgba(255,107,0,0.65); box-shadow: 0 14px 26px rgba(255,107,0,0.12); }

        .cal-day{ font-weight: 300; font-size: 12px; }
        .cal-price{ font-weight: 300; font-size: 12px; margin-top: 6px; }
        .cal-route{ color: var(--muted); font-weight: 300; font-size: 10px; margin-top: 2px; }

        .cal-detail{
            margin-top: 10px;
            border: 1px solid rgba(0,0,0,0.10);
            border-radius: 16px;
            padding: 10px;
            background: linear-gradient(135deg, #fff, #f8fafc);
        }
        .cal-detail .t{ font-weight: 300; font-size: 12px; }
        .cal-detail .s{ color: var(--muted); font-weight: 300; font-size: 12px; margin-top: 2px; }

        .an-ins{ margin-top: 10px; display:grid; gap: 8px; }
        .an-ins .row{ display:flex; justify-content:space-between; gap: 10px; font-weight: 300; font-size: 12px; }
        .an-ins .row .k{ color: var(--muted); }
        .an-ins .row .v{ color: #0f172a; }

        .an-note{
            margin-top: 12px;
            color: var(--muted);
            font-weight: 600;
            font-size: 12px;
            line-height: 1.35;
        }
        /* =========================
           Scan button loading state
           ========================= */
        [data-scan-btn]{
            display:inline-flex;
            align-items:center;
            justify-content:center;
            gap:10px;
        }

        .btn-spinner{
            width:16px;
            height:16px;
            border-radius:50%;
            border:2px solid rgba(255,255,255,0.35);
            border-top-color: rgba(255,255,255,0.95);
            display:none;
            animation: ssSpin .8s linear infinite;
        }

        @@keyframes ssSpin { to { transform: rotate(360deg); } }

        [data-scan-btn].is-loading{
            cursor: progress;
            filter: saturate(0.95);
        }
        [data-scan-btn].is-loading .btn-spinner{ display:inline-block; }
        [data-scan-btn].is-loading .btn-glint{ opacity:0; }

        /* =========================
           Deals skeleton while loading
           ========================= */
        .deals-skeleton{
            padding: 12px;
            display:grid;
            gap:10px;
        }
        .deals-skeleton .sk{
            height: 62px;
            border-radius: 16px;
            border: 1px solid rgba(0,0,0,0.08);
            background: linear-gradient(
                90deg,
                rgba(15,23,42,0.06) 0%,
                rgba(15,23,42,0.12) 40%,
                rgba(15,23,42,0.06) 80%
            );
            background-size: 240% 100%;
            animation: skMove 1.1s ease-in-out infinite;
        }
@@keyframes skMove{
             0%{ background-position: 100% 0; }
             100%{ background-position: 0% 0; }
}


        /* Make the mobile action bar stack nicely */
        @@media (max-width: 991px) {
        .map-actions-top .bar { flex-direction: column; }
}

        /* =========================
           Mobile fullscreen map
           ========================= */
        .map-fs { overflow: hidden; }

        /* Hide everything except map column while fullscreen is active */
        .map-fs #heroCard,
        .map-fs #search,
        .map-fs #deals { display: none !important; }

        /* Hide the map card header + normal mobile action bar while fullscreen is active */
        .map-fs .map-col .ss-card-header,
        .map-fs .map-actions-top { display: none !important; }

        /* Make the map fill the whole viewport */
        .map-fs #map {
            position: fixed;
            inset: 0;
            width: 100vw;
            height: 100vh;
            border-radius: 0;
            border: none;
            z-index: 10000;
        }

        /* Fullscreen top bar */
        .map-fs-bar{
            position: fixed;
            left: 0;
            right: 0;
            top: env(safe-area-inset-top, 0px);
            z-index: 10001;

            display: none;               /* toggled by JS */
            align-items: center;
            justify-content: space-between;
            gap: 10px;

            padding: 10px 12px;
            background: rgba(255,255,255,0.92);
            border-bottom: 1px solid rgba(0,0,0,0.10);
            backdrop-filter: blur(10px);
        }

        .map-fs-title{
            font-weight: 700;
            font-size: 13px;
            color: var(--text);
            opacity: 0.9;
        }
        

    </style>
}

