        // Highlight routes + markers in routesLayer/markersLayer using dealIndex/metaType
        function highlightSelectedDealsOnMap(indices) {
            const set = new Set(indices || []);

            // Routes
            routesLayer.eachLayer(l => {
                if (l?.options?.metaType !== "deal") return;
                const isOn = set.size === 0 ? true : set.has(l.options.dealIndex);

                // polyline supports setStyle
                if (typeof l.setStyle === "function") {
                    l.setStyle({
                        opacity: isOn ? 0.55 : 0.06,
                        weight: isOn ? 2.6 : 1.2
                    });
                }
            });

            // Deal markers
            markersLayer.eachLayer(m => {
                if (m?.options?.metaType !== "deal") return;
                const isOn = set.size === 0 ? true : set.has(m.options.dealIndex);

                // circleMarker supports setStyle
                if (typeof m.setStyle === "function") {
                    m.setStyle({
                        opacity: isOn ? 1 : 0.15,
                        fillOpacity: isOn ? 0.95 : 0.10,
                        weight: isOn ? 4 : 2
                    });
                } else if (typeof m.setOpacity === "function") {
                    // just in case a different marker type lands here later
                    m.setOpacity(isOn ? 1 : 0.15);
                }
            });
        }

